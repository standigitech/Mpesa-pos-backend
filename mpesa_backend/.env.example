# Environment
NODE_ENV=development

# Port
PORT=3000

# M-Pesa API Credentials
CONSUMER_KEY=your_consumer_key_here
CONSUMER_SECRET=your_consumer_secret_here
SHORTCODE=your_test_till_number
PASSKEY=your_passkey_here

# Callback URL (must be a publicly reachable HTTPS URL for Safaricom callbacks)
CALLBACK_URL=https://your-public-domain.example/api

# Production/Staging settings (uncomment for production)
# MPESA_API_URL=https://api.safaricom.co.ke
# SANDBOX_API_URL=https://sandbox.safaricom.co.ke
